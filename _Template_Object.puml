@startuml
' ============================================================
'  オブジェクト図 記法リファレンス（「こう書くとこうなる」集）
'  クラスを実体化した「ある瞬間の値」を表す。※コメントは行頭の ' のみ。
' ============================================================
title オブジェクト図 記法リファレンス

' ▼ オブジェクトはこう： object "インスタンス名 : クラス名" { 属性 = 値 }
'   クラス図と違い、属性に「実際の値」を入れるのがポイント
object "tanaka : User" as t {
  id = 1
  name = "田中"
}

object "order1 : Order" as o {
  total = 3000
  status = "受付"
}

' ▼ インスタンス同士のつながりはこう： -->
t --> o : 注文した

' ▼ JSONデータを図にしたいときはこう： json 名前 { ... }
json 設定 {
  "theme": "dark",
  "size": ["S", "M", "L"]
}

@enduml
